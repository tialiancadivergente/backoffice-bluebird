# Em desenvolvimento local, o Vite usa proxy para evitar erro de CORS no browser.
# No dev, prefira manter a chave no proxy (nao exposta no navegador):
# LEADS_API_KEY=coloque_sua_chave_aqui
# Para build/execucao sem proxy local, use:
# VITE_LEADS_API_KEY=coloque_sua_chave_aqui

# Target do proxy para o leads-api (lead-score backend).
# Local: aponte para o processo local. Em producao nao precisa definir (usa URL de prod).
# LEADS_API_TARGET=http://localhost:3000
